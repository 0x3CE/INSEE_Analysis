# INSEE API (https://api.insee.fr/catalogue/)
# Register at https://api.insee.fr/catalogue/ to get a key
INSEE_API_KEY=your_insee_api_key_here

# data.gouv.fr API (optional — public endpoints work without key)
DATAGOUV_API_KEY=your_datagouv_api_key_here

# DBnomics (no key required — public API)
# DBNOMICS_BASE_URL is set to default in the client

# Next.js ISR revalidation interval (seconds)
REVALIDATE_SECONDS=3600
